# ---- Database ----
# When running via Docker Compose this is overridden by compose to use the `db` host.
DATABASE_URL=postgresql+psycopg2://commercio:commercio@localhost:5432/commercio

# ---- Clerk (auth) ----
# Found in the Clerk dashboard. Used to verify the JWT sent by the frontend.
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-app.clerk.accounts.dev
# Optional: expected audience claim, if you configure one in Clerk.
CLERK_AUDIENCE=

# ---- Mistral (LLM) ----
MISTRAL_API_KEY=
# Optional: override the model (default: mistral-small-latest)
MISTRAL_MODEL=mistral-small-latest

# ---- App ----
# Comma-separated list of allowed CORS origins (the frontend dev server).
CORS_ORIGINS=http://localhost:5173
# Set to false to require a valid Clerk token on protected routes.
AUTH_DISABLED=true
